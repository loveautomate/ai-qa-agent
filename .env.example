# Copy to `.env` in the repo root (do not commit `.env`).
# Loaded automatically by `playwright.config.ts` when dotenv is enabled.

# UI E2E base URL (used as Playwright `baseURL` for `page.goto('/')`-style tests)
E2E_BASE_URL=https://www.saucedemo.com/

# API base URL for `APIRequestContext` / REST tests (no trailing slash preferred for path joins)
API_BASE_URL=https://petstore.swagger.io/v2
